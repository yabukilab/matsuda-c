<script>
    document.getElementById('car_number').addEventListener('change', function() {
        let carNumber = this.value;
        if (carNumber) {
            fetch(`get_seats.php?car_number=${carNumber}`)
                .then(response => response.json())
                .then(data => {
                    let seatSelection = document.getElementById('seat-selection');
                    seatSelection.innerHTML = '';
                    data.forEach(seat => {
                        let button = document.createElement('button');
                        button.type = 'button';
                        button.className = 'seat-btn';
                        button.dataset.seatId = seat.seat_id; // Change to seat_id
                        button.innerText = seat.seat_id; // Change to seat_id
                        seatSelection.appendChild(button);
                    });
                    document.querySelectorAll('.seat-btn').forEach(button => {
                        button.addEventListener('click', function() {
                            document.querySelectorAll('.seat-btn').forEach(btn => btn.classList.remove('selected'));
                            this.classList.add('selected');
                            document.getElementById('selected_seat_id').value = this.getAttribute('data-seat-id');
                        });
                    });
                });
        }
    });
</script>
