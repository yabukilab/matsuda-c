            ["seat_number" => "1B", "car_number" => 4, "is_reserved" => 1],
            ["seat_number" => "1C", "car_number" => 4, "is_reserved" => 0],
            ["seat_number" => "1D", "car_number" => 4, "is_reserved" => 0],
            ["seat_number" => "2A", "car_number" => 4, "is_reserved" => 0],
            ["seat_number" => "2B", "car_number" => 4, "is_reserved" => 0],
