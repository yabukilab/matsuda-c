            ["seat_number" => "2D", "car_number" => 4, "is_reserved" => 0],
            // 他の座席データも同様に追加
        ];

        // 座席表の表示
        foreach ($seats as $seat) {
            $seatNumber = $seat['seat_number'];
            $isReserved = $seat['is_reserved'] ? "reserved" : "available";
            $buttonClass = "seat-btn $isReserved";
            echo "<button type='button' class='$buttonClass' data-seat-id='$seatNumber'>$seatNumber</button>";
        }
